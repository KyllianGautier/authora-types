{
  "name": "@kylliangautier/authora-types",
  "version": "0.0.0",
  "description": "Shared TypeScript interfaces for Authora",
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "link:create": "npm run build && npm link && npm list -g --link",
    "link:remove": "npm unlink -g @kylliangautier/authora-types",
    "docs": "typedoc src/index.ts"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "typedoc": "^0.28.17",
    "typescript": "^5.7.3"
  }
}
